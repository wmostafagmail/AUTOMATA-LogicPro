{
  "project_name": "mini_cpu_core",
  "vhdl_standard": "VHDL-2008",
  "top_entity": "cpu_core",
  "top_testbench": "tb_cpu_core",
  "target_fpga": "Generic Portable",
  "clock_mhz": 100,
  "reset_style": "synchronous_active_high",
  "files": [
    "src/cpu_pkg.vhd",
    "src/cpu_core.vhd",
    "tb/tb_cpu_core.vhd",
    "constraints/cpu_core.xdc",
    "Makefile",
    "sim/run_ghdl.sh",
    "README.md"
  ],
  "ghdl_commands": [
    "ghdl -a --std=08 --workdir=work src/cpu_pkg.vhd",
    "ghdl -a --std=08 --workdir=work src/cpu_core.vhd",
    "ghdl -a --std=08 --workdir=work tb/tb_cpu_core.vhd",
    "ghdl -e --std=08 --workdir=work tb_cpu_core",
    "ghdl -r --std=08 --workdir=work tb_cpu_core"
  ],
  "verification_notes": "Self-checking testbench validates arithmetic, logic, and fetch behavior. Expects std.env.stop(0) with zero assertion failures."
}